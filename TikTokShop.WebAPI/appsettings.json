{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TikTokShop": "Debug"
    }
  },
  "AllowedHosts": "*",

  // ── TikTok App Credentials ───────────────────────────────────
  // ดูค่าจริงได้ที่: https://partner.tiktokshop.com/datahub/app
  // ค่านี้จะถูก Override โดย appsettings.Development.json (ห้าม Commit ค่าจริง)
  "TikTok": {
    "AppKey": "",
    "AppSecret": "",
    "BaseUrl": "https://open-api.tiktokglobalshop.com"
  },

  // ── Multi-Tenant Shop Credentials ───────────────────────────
  // เพิ่ม/ลด Tenant ได้โดยเพิ่ม Object ใหม่ใน appsettings.Development.json
  // Key = TenantCode ที่ใช้เรียก API เช่น GET /api/orders/PoC_MobileShop_01
  "TikTokTenants": {
    "PoC_MobileShop_01": {
      "ShopName": "ร้านตัวอย่าง 1",
      "AccessToken": "",
      "ShopCipher": "",
      "ShopId": ""
    }
  }
