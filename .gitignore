# ================================================================
# .gitignore สำหรับ TikTok Shop PoC — .NET 8 / ASP.NET Core
# ================================================================

# ── Build Output ─────────────────────────────────────────────────
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# ── Visual Studio ─────────────────────────────────────────────────
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# ── Rider / JetBrains ─────────────────────────────────────────────
.idea/
*.sln.iml

# ── VSCode ────────────────────────────────────────────────────────
.vscode/

# ── NuGet Packages ────────────────────────────────────────────────
# Packages จะถูก Restore ผ่าน dotnet restore อัตโนมัติ
packages/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/

# ── .NET Runtime ──────────────────────────────────────────────────
*.dll
*.exe
*.pdb
*.cache
*.ilk
*.meta
*.obj

# ── Publish Output ────────────────────────────────────────────────
publish/
[Pp]ublish/

# ── Test Results ──────────────────────────────────────────────────
TestResults/
[Tt]est[Rr]esult*/
*.trx
coverage/
*.coveragexml
*.coverage

# ── Entity Framework Migrations (ถ้าใช้) ─────────────────────────
# Uncomment ถ้าไม่ต้องการ Track migrations
# Migrations/

# ── App Settings ที่มีข้อมูลลับ ───────────────────────────────────
# ⚠️ สำคัญมาก! ไฟล์เหล่านี้มี Token / Secret จริง ห้าม Commit เด็ดขาด
appsettings.Development.json
appsettings.Production.json
appsettings.Staging.json
appsettings.Sandbox.json
appsettings.RealShop.json
appsettings.*.local.json
secrets.json
.env
.env.*

# ── OS ────────────────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ── Docker (เผื่อเพิ่มในอนาคต) ────────────────────────────────────
# .dockerignore ควรมีแยกต่างหาก แต่เพิ่มไว้เผื่อ
docker-compose.override.yml

# ── Azure (เผื่อ Deploy Azure ในอนาคต) ───────────────────────────
.azure/
*.PublishSettings
